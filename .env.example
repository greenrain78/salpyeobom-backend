DATABASE_URL=postgres://user:pass@localhost:5432/salpyeobom
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# 허용할 프론트엔드 Origin (쉼표 구분, 운영 시 실제 도메인으로 변경)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5500

# 이메일(Resend) — 보고서 이메일 전송에 사용
# API 키: https://resend.com/api-keys
# 외부 수신자에게 보내려면 salpyeobom.kro.kr 을 Resend 에서 도메인 인증해야 함.
# 인증 전 테스트: RESEND_FROM=살펴봄 <onboarding@resend.dev> (본인 계정 이메일로만 발송)
RESEND_API_KEY=
RESEND_FROM=살펴봄 <noreply@salpyeobom.kro.kr>
